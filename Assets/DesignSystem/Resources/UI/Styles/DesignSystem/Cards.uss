/* ============================================================================
   CARDS
   - Generic surface (.ds-card)
   - Animal card (collection grid item) with rarity-aware border + selection
   - Animal detail page (full panel)
   ============================================================================ */

/* ---------- Generic card ---------- */
.ds-card {
    background-color: var(--color-surface);
    border-width: var(--border-thin);
    border-color: var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
}

.ds-card--elevated {
    background-color: var(--color-surface-elev);
}

.ds-card--padded { padding: var(--space-5); }
.ds-card--flush  { padding: 0; }

/* ---------- Animal card (grid item) ---------- */
.ds-animal-card {
    width: 200px;
    background-color: var(--color-surface);
    border-width: var(--border-regular);
    border-color: var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
    transition-property: border-color, scale;
    transition-duration: var(--transition-fast);
}

.ds-animal-card:hover { border-color: var(--color-border-strong); }
.ds-animal-card.is-selected { border-color: var(--color-primary); }

/* Rarity-aware border (apply alongside .ds-animal-card) */
.ds-animal-card.is-rare       { border-color: var(--color-rarity-rare); }
.ds-animal-card.is-epic       { border-color: var(--color-rarity-epic); }
.ds-animal-card.is-legendary  { border-color: var(--color-rarity-legendary); }
.ds-animal-card.is-common     { border-color: var(--color-rarity-common); }

/* Selection check pill in upper-right */
.ds-animal-card__check {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-pill-12); /* 24×24 → circle */
    background-color: var(--color-primary);
    align-items: center;
    justify-content: center;
}
.ds-animal-card__check-icon {
    width: 14px;
    height: 14px;
    -unity-background-image-tint-color: var(--color-text-on-accent);
}

/* Image area */
.ds-animal-card__image {
    width: 100%;
    height: 110px;
    border-radius: var(--radius-md);
    background-color: var(--color-surface-elev);
    margin-bottom: var(--space-3);
    align-items: center;
    justify-content: center;
}

/* Rarity chip pinned over the bottom of the image */
.ds-animal-card__rarity {
    align-self: center;
    margin-bottom: var(--space-2);
}

/* Title row + star */
.ds-animal-card__title-row {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-3);
}
.ds-animal-card__title {
    font-size: var(--font-size-h3);
    -unity-font-style: bold;
    color: var(--color-text-primary);
    margin-right: var(--space-1);
}
.ds-animal-card__star {
    width: 14px;
    height: 14px;
    -unity-background-image-tint-color: var(--color-warning);
}

/* "Equipped" / "Equip" footer slot — pair with .ds-text-success or a button */
.ds-animal-card__footer {
    align-items: center;
}

/* ---------- Animal detail page ---------- */
.ds-animal-detail {
    background-color: var(--color-surface);
    border-width: var(--border-thin);
    border-color: var(--color-border);
    border-radius: var(--radius-lg);
    padding: 0;
    overflow: hidden;
    width: 360px;
}

.ds-animal-detail__hero {
    width: 100%;
    height: 220px;
    background-color: var(--color-surface-elev);
    align-items: center;
    justify-content: center;
}

/* Top-left back / top-right more buttons floating over hero */
.ds-animal-detail__hero-back {
    position: absolute;
    top: 12px;
    left: 12px;
}
.ds-animal-detail__hero-more {
    position: absolute;
    top: 12px;
    right: 12px;
}

/* Carousel dots */
.ds-carousel-dots {
    position: absolute;
    bottom: 10px;
    flex-direction: row;
    align-self: center;
}
.ds-carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-pill-3); /* circle when 6×6, still half-height pill when active */
    background-color: rgba(255, 255, 255, 0.35);
    margin-left: 3px;
    margin-right: 3px;
}
.ds-carousel-dot.is-active {
    background-color: #FFFFFF;
    width: 18px;
}

/* Body */
.ds-animal-detail__body {
    padding: var(--space-4);
}

.ds-animal-detail__header-row {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
}

.ds-animal-detail__title-block {
    flex-direction: row;
    align-items: center;
}

.ds-animal-detail__description {
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
    white-space: normal;
}

/* Info rows (Rarity / Habitat / Energy / Discovered) */
.ds-info-row {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    height: 32px;
}
.ds-info-row__left {
    flex-direction: row;
    align-items: center;
}
.ds-info-row__icon {
    width: 16px;
    height: 16px;
    margin-right: var(--space-2);
    -unity-background-image-tint-color: var(--color-text-secondary);
}
.ds-info-row__label {
    color: var(--color-text-secondary);
    font-size: var(--font-size-body-1);
}
.ds-info-row__value {
    color: var(--color-text-primary);
    font-size: var(--font-size-body-1);
    -unity-font-style: bold;
}

/* Footer action row — Unequip + View Skins */
.ds-animal-detail__actions {
    flex-direction: row;
    margin-top: var(--space-4);
}
.ds-animal-detail__actions > .ds-btn {
    flex-grow: 1;
    margin-left: var(--space-2);
    margin-right: var(--space-2);
}
/* :first-child / :last-child are not supported in Unity USS.
   Use a negative outer margin on the actions row, or apply a utility class in
   UXML to zero out the edge margin on the first/last button if needed. */
